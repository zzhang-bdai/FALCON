  <link name="torso_link">
    <inertial>
      <!-- Measured an additional 3.4kg on Pippin (newer G1 version) so adding it to the original 6.78kg of the torso -->
      <!-- The battery weighs 2.5kg, we're assuming this is missing from the URDF. -->
      <!-- We added hoist straps and e-stop, which probably round up to about 0.5kg -->
      <!-- The missing 0.4kg could likely be due to unmodeled wires, straps and little things like -->
      <!-- We're assuming that the 3.4kg can be added to the torso as most of it  is attached to that link -->
      <!-- So original 6.78 + 3.4 = 10.18 -->
      <!-- Note that on the older G1 version, we have only a 2.5kg difference (as measured with Bilbo), we're assuming that the old G1 will get rolled out and doesn't need to be accurate. -->
      <origin rpy="0 0 0" xyz="0.000931 0.000346 0.15082"/>
      <mass value="10.18"/>
      <!-- The mass is multiplied by 1.5, assuming an uniform change in density the inertia also gets multiplied by the same amount -->
      <inertia ixx="0.088575" ixy="4.99530E-05" ixz="-0.00265725" iyy="0.070521" iyz="-3.35985E-05" izz="0.038478"/>
    </inertial>
