      <!-- The CoM was computed from the mesh assuming uniform density -->
      <origin rpy="0 0 0" xyz="-0.090583 0 0.21618"/>
      <!-- The mass and inertia are very approximative, we have not measured the actual mass of the backpack, but it adds 1kg to the overall weight. -->
      <mass value="1.0"/>
      <!-- The inertia was computer assuming a sphere of 5cm radius and mass of 1kg -->
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="/workspace/humanoidverse/data/robots/g1/meshes/visual/backpacks/halo_backpack_v0.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="/workspace/humanoidverse/data/robots/g1/meshes/collision/backpacks/halo_backpack_v0.obj"/>
      </geometry>
    </collision>
  </link>
  <link name="imu_torso">
    <sensor_intrinsics type="imu">
      <accelerometer bias="0.0" noise="1e-06"/>
      <gyroscope bias="0.0" noise="1e-06"/>
    </sensor_intrinsics>
    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <mass value="1e-06"/>
      <inertia ixx="1e-06" ixy="0.0" ixz="0.0" iyy="1e-06" iyz="0.0" izz="1e-06"/>
    </inertial>
  </link>
  <joint name="joint_imu_torso" type="fixed">
    <parent link="imu_in_torso"/>
    <child link="imu_torso"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <link name="imu_pelvis">
    <sensor_intrinsics type="imu">
      <accelerometer bias="0.0" noise="1e-06"/>
      <gyroscope bias="0.0" noise="1e-06"/>
    </sensor_intrinsics>
    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <mass value="1e-06"/>
      <inertia ixx="1e-06" ixy="0.0" ixz="0.0" iyy="1e-06" iyz="0.0" izz="1e-06"/>
    </inertial>
  </link>
  <joint name="joint_imu_pelvis" type="fixed">
    <parent link="imu_in_pelvis"/>
    <child link="imu_pelvis"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
